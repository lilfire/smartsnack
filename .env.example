# Required: secret key for Flask session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SMARTSNACK_SECRET_KEY=

# Optional: protect backup/restore/import endpoints with an API key
# When unset, these endpoints are publicly accessible.
SMARTSNACK_API_KEY=

# Optional: path to SQLite database (default: /data/smartsnack.sqlite in Docker, ./smartsnack.sqlite for local dev)
# DB_PATH=./smartsnack.sqlite
